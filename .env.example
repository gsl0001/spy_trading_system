# ===== SPY Trading System Environment Variables =====
# Copy this file to .env and fill in your values

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# Broker (IBKR)
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=1

# Notifications (Discord)
DISCORD_WEBHOOK_URL=

# Notifications (Email - optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_TO=

# Mode: "paper" or "live"
TRADING_MODE=paper

# Data
FRED_API_KEY=
